\", mw(http.HandlerFunc(h.unbanUser)))\n    60→\tmux.Handle(\"GET /api/admin/stats\", mw(http.HandlerFunc(h.getStats)))\n    61→\tmux.Handle(\"GET /api/admin/qualities\", mw(http.HandlerFunc(h.getQualities)))\n    62→\tmux.Handle(\"PUT /api/admin/qualities\", mw(http.HandlerFunc(h.updateQualities)))\n    63→\tmux.Handle(\"POST /api/admin/icon\", mw(http.HandlerFunc(h.uploadIcon)))\n    64→}\n    65→\n    66→func (h *Handler) getSettings(w http.ResponseWriter, r *http.Request) {\n    67→\tsettings, err := h.store.GetSettings(r.Context())\n    68→\tif err != nil {\n    69→\t\tslog.Error(\"admin: get settings\", \"err\", err)\n    70→\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n    71→\t\treturn\n    72→\t}\n    73→\twriteJSON(w, http.StatusOK, settings)\n    74→}\n    75→\n    76→func (h *Handler) updateSettings(w http.ResponseWriter, r *http.Request) {\n    77→\tvar kv map[string]string\n    78→\tif err := json.NewDecoder(r.Body).Decode(&kv); err != nil {\n    79→\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"invalid JSON\"})\n    80→\t\treturn\n    81→\t}\n    82→\tif len(kv) == 0 {\n    83→\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"empty payload\"})\n    84→\t\treturn\n    85→\t}\n    86→\n    87→\tif err := h.store.UpdateSettings(r.Context(), kv); err != nil {\n    88→\t\tslog.Error(\"admin: update settings\", \"err\", err)\n    89→\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n    90→\t\treturn\n    91→\t}\n    92→\n    93→\tsettings, err := h.store.GetSettings(r.Context())\n    94→\tif err != nil {\n    95→\t\tslog.Error(\"admin: get settings after update\", \"err\", err)\n    96→\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n    97→\t\treturn\n    98→\t}\n    99→\twriteJSON(w, http.StatusOK, settings)\n   100→}\n   101→\n   102→func (h *Handler) listUsers(w http.ResponseWriter, r *http.Request) {\n   103→\tusers, err := h.store.ListUsers(r.Context())\n   104→\tif err != nil {\n   105→\t\tslog.Error(\"admin: list users\", \"err\", err)\n   106→\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n   107→\t\treturn\n   108→\t}\n   109→\twriteJSON(w, http.StatusOK, users)\n   110→}\n   111→\n   112→type banRequest struct {\n   113→\tUserID int64  `json:\"user_id\"`\n   114→\tReason string `json:\"reason\"`\n   115→}\n   116→\n   117→func (h *Handler) banUser(w http.ResponseWriter, r *http.Request) {\n   118→\tvar req banRequest\n   119→\tif err := json.NewDecoder(r.Body).Decode(&req); err != nil {\n   120→\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"invalid JSON\"})\n   121→\t\treturn\n   122→\t}\n   123→\tif req.UserID == 0 {\n   124→\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"user_id is required\"})\n   125→\t\treturn\n   126→\t}\n   127→\n   128→\tclaims := auth.ClaimsFromContext(r.Context())\n   129→\tif claims.UserID == req.UserID {\n   130→\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"cannot ban yourself\"})\n   131→\t\treturn\n   132→\t}\n   133→\n   134→\tif err := h.store.BanUser(r.Context(), req.UserID, claims.UserID, req.Reason); err != nil {\n   135→\t\tif strings.Contains(err.Error(), \"UNIQUE constraint failed\") {\n   136→\t\t\twriteJSON(w, http.StatusConflict, map[string]string{\"error\": \"user already banned\"})\n   137→\t\t\treturn\n   138→\t\t}\n   139→\t\tslog.Error(\"admin: ban user\", \"err\", err)\n   140→\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n   141→\t\treturn\n   142→\t}\n   143→\twriteJSON(w, http.StatusOK, map[string]string{\"status\": \"banned\"})\n   144→}\n   145→\n   146→func (h *Handler) unbanUser(w http.ResponseWriter, r *http.Request) {\n   147→\tidStr := r.PathValue(\"userId\")\n   148→\tuserID, err