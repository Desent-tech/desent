            "content": "#!/usr/bin/env bash\nset -euo pipefail\n\n# ─── Colors & Symbols ────────────────────────────────────────────────\nRED='\\033[0;31m'\nGREEN='\\033[0;32m'\nCYAN='\\033[0;36m'\nBOLD='\\033[1m'\nDIM='\\033[2m'\nRESET='\\033[0m'\n\nTICK=\"✓\"\nCROSS=\"✗\"\nSPINNER_FRAMES=(⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏)\n\nTOTAL_STEPS=7\nCURRENT_STEP=0\nSPINNER_PID=\"\"\nLOG_FILE=\"/tmp/deploy-desent-$$.log\"\n\n# ─── Cleanup ─────────────────────────────────────────────────────────\ncleanup() {\n    kill_spinner\n    # Remove temp files\n    rm -f /tmp/docker-compose.prod.yml.$$ 2>/dev/null || true\n}\ntrap cleanup EXIT\n\n# ─── Terminal UX ─────────────────────────────────────────────────────\nbanner() {\n    echo \"\"\n    printf \"${BOLD}${CYAN}\"\n    cat <<'ART'\n     _                      _\n  __| | ___  ___  ___ _ __ | |_\n / _` |/ _ \\/ __|/ _ \\ '_ \\| __|\n| (_| |  __/\\__ \\  __/ | | | |_\n \\__,_|\\___||___/\\___|_| |_|\\__|\n\nART\n    printf \"${RESET}\"\n    printf \"${DIM}  Decentralized Streaming Platform — Deploy${RESET}\\n\"\n    echo \"\"\n}\n\nkill_spinner() {\n    if [[ -n \"$SPINNER_PID\" ]] && kill -0 \"$SPINNER_PID\" 2>/dev/null; then\n        kill \"$SPINNER_PID\" 2>/dev/null\n        wait \"$SPINNER_PID\" 2>/dev/null || true\n    fi\n    SPINNER_PID=\"\"\n}\n\nspinner() {\n    local msg=\"$1\"\n    local i=0\n    tput civis 2>/dev/null || true  # hide cursor\n    while true; do\n        printf \"\\r  ${DIM}[%d/%d]${RESET} ${CYAN}%s${RESET} %s \" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"${SPINNER_FRAMES[$i]}\" \"$msg\"\n        i=$(( (i + 1) % ${#SPINNER_FRAMES[@]} ))\n        sleep 0.08\n    done\n}\n\nstep() {\n    local msg=\"$1\"\n    shift\n    CURRENT_STEP=$((CURRENT_STEP + 1))\n\n    # Start spinner\n    spinner \"$msg\" &\n    SPINNER_PID=$!\n\n    # Run command, capture output\n    local rc=0\n    \"$@\" >>\"$LOG_FILE\" 2>&1 || rc=$?\n\n    # Stop spinner\n    kill_spinner\n    tput cnorm 2>/dev/null || true  # restore cursor\n\n    if [[ $rc -eq 0 ]]; then\n        printf \"\\r  ${DIM}[%d/%d]${RESET} ${GREEN}${TICK}${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$msg\"\n    else\n        printf \"\\r  ${DIM}[%d/%d]${RESET} ${RED}${CROSS}${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$msg\"\n        echo \"\"\n        printf \"  ${RED}${BOLD}Error:${RESET} Step failed. Last 20 lines of log:\\n\"\n        echo \"\"\n        tail -20 \"$LOG_FILE\" | sed 's/^/    /'\n        echo \"\"\n        printf \"  ${DIM}Full log: %s${RESET}\\n\" \"$LOG_FILE\"\n        exit 1\n    fi\n}\n\nfatal() {\n    kill_spinner\n    tput cnorm 2>/dev/null || true\n    printf \"\\n  ${RED}${BOLD}Fatal:${RESET} %s\\n\\n\" \"$1\"\n    exit 1\n}\n\n# ─── Prerequisite checks ────────────────────────────────────────────\ncheck_deps() {\n    local missing=()\n    if ! command -v docker &>/dev/null; then\n        missing+=(\"docker\")\n    fi\n    if ! command -v sshpass &>/dev/null; then\n        missing+=(\"sshpass\")\n    fi\n    if [[ ${#missing[@]} -gt 0 ]]; then\n        printf \"  ${RED}${BOLD}Missing dependencies:${RESET} %s\\n\\n\" \"${missing[*]}\"\n        for dep in \"${missing[@]}\"; do\n            case \"$dep\" in\n                sshpass)\n                    printf \"  Install sshpass:\\n\"\n                    printf \"    ${DIM}macOS:${RESET}  brew install sshpass  ${DIM}(or: brew install hudochenkov/sshpass/sshpass)${RESET}\\n\"\n                    printf \"    ${DIM}Ubuntu:${RESET} sudo apt install sshpass\\n\"\n                    ;;\n                docker)\n                    printf \"  Install Docker: https://docs.docker.com/get-docker/\\n\"\n                    ;;\n            esac\n        done\n        echo \"\"\n        exit 1\n    fi\n}\n\n# ─── Remote SSH helper ───────────────────────────────────────────────\nremote() {\n    sshpass -p \"$SERVER_PASS\" ssh \\\n        -o StrictHostKeyChecking=no \\\n        -o UserKnownHostsFile=/dev/null \\\n        -o LogLevel=ERROR \\\n        -o ConnectTimeout=10 \\\n        \"$SERVER_USER@$SERVER_IP\" \"$@\"\n}\n\nremote_scp() {\n    sshpass -p \"$SERVER_PASS\" scp \\\n        -o StrictHostKeyChecking=no \\\n        -o UserKnownHostsFile=/dev/null \\\n        -o LogLevel=ERROR \\\n        \"$@\"\n}\n\n# ─── Step implementations ────────────────────────────────────────────\n\ndo_test_ssh() {\n    remote echo \"SSH connection OK\"\n}\n\ndo_install_docker() {\n    remote bash -s <<'SCRIPT'\nif command -v docker &>/dev/null; then\n    echo \"Docker already installed: $(docker --version)\"\n    # Make sure Docker is running\n    systemctl start docker 2>/dev/null || service docker start 2>/dev/null || true\n    exit 0\nfi\n\necho \"Installing Docker...\"\nexport DEBIAN_FRONTEND=noninteractive\n\n# Install via official convenience script\ncurl -fsSL https://get.docker.com | sh\n\n# Enable and start\nsystemctl enable docker 2>/dev/null || true\nsystemctl start docker 2>/dev/null || service docker start 2>/dev/null || true\n\n# Add current user to docker group\nusermod -aG docker \"$(whoami)\" 2>/dev/null || true\n\necho \"Docker installed: $(docker --version)\"\nSCRIPT\n}\n\ndo_build_images() {\n    echo \"Building desent-server image...\"\n    docker build --platform linux/amd64 -t desent-server .\n\n    echo \"Building desent-web image...\"\n    docker build --platform linux/amd64 -t desent-web ./web/liches-web\n}\n\ndo_transfer_images() {\n    echo \"Saving and transferring desent-server...\"\n    if command -v pv &>/dev/null; then\n        docker save desent-server | pv | sshpass -p \"$SERVER_PASS\" ssh \\\n            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR \\\n            \"$SERVER_USER@$SERVER_IP\" \"docker load\"\n    else\n        docker save desent-server | sshpass -p \"$SERVER_PASS\" ssh \\\n            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR \\\n            \"$SERVER_USER@$SERVER_IP\" \"docker load\"\n    fi\n\n    echo \"Saving and transferring desent-web...\"\n    if command -v pv &>/dev/null; then\n        docker save desent-web | pv | sshpass -p \"$SERVER_PASS\" ssh \\\n            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR \\\n            \"$SERVER_USER@$SERVER_IP\" \"docker load\"\n    else\n        docker save desent-web | sshpass -p \"$SERVER_PASS\" ssh \\\n            -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR \\\n            \"$SERVER_USER@$SERVER_IP\" \"docker load\"\n    fi\n}\n\ndo_generate_config() {\n    local jwt_secret\n    jwt_secret=$(openssl rand -hex 32)\n\n    cat > /tmp/docker-compose.prod.yml.$$ <<YAML\nservices:\n  traefik:\n    image: traefik:v3.3\n    command:\n      - --api.insecure=true\n      - --providers.docker=true\n      - --providers.docker.exposedbydefault=false\n      - --entrypoints.web.address=:80\n    ports:\n      - \"80:80\"\n      - \"8080:8080\"\n    volumes:\n      - /var/run/docker.sock:/var/run/docker.sock:ro\n    restart: unless-stopped\n\n  server:\n    image: desent-server:latest\n    labels:\n      - traefik.enable=true\n      - \"traefik.http.routers.api.rule=PathPrefix(\\`/api\\`) || PathPrefix(\\`/ws\\`) || PathPrefix(\\`/live\\`) || PathPrefix(\\`/health\\`)\"\n      - traefik.http.routers.api.entrypoints=web\n      - traefik.http.services.api.loadbalancer.server.port=8080\n    ports:\n      - \"1935:1935\"\n    environment:\n      - JWT_SECRET=${jwt_secret}\n      - STREAM_KEY=live\n      - DB_PATH=/data/desent.db\n      - HLS_DIR=/tmp/hls\n      - HTTP_ADDR=:8080\n      - RTMP_ADDR=0.0.0.0:1935\n    volumes:\n      - db-data:/data\n    restart: unless-stopped\n\n  web:\n    image: desent-web:latest\n    labels:\n      - traefik.enable=true\n      - \"traefik.http.routers.web.rule=PathPrefix(\\`/\\`)\"\n      - traefik.http.routers.web.entrypoints=web\n      - traefik.http.routers.web.priority=1\n      - traefik.http.services.web.loadbalancer.server.port=3000\n    environment:\n      - NEXT_PUBLIC_BACKEND_URL=http://${SERVER_IP}\n    depends_on:\n      - server\n    restart: unless-stopped\n\nvolumes:\n  db-data:\nYAML\n\n    # Create deploy directory on remote\n    remote mkdir -p /opt/desent\n\n    # Transfer compose file\n    remote_scp /tmp/docker-compose.prod.yml.$$ \"$SERVER_USER@$SERVER_IP:/opt/desent/docker-compose.yml\"\n\n    rm -f /tmp/docker-compose.prod.yml.$$\n}\n\ndo_deploy() {\n    remote bash -s <<'SCRIPT'\ncd /opt/desent\n\n# Stop existing containers if any\ndocker compose down 2>/dev/null || true\n\n# Start fresh\ndocker compose up -d\n\necho \"Containers started.\"\ndocker compose ps\nSCRIPT\n}\n\ndo_verify() {\n    local max_attempts=30\n    local attempt=0\n\n    echo \"Waiting for server to become healthy...\"\n    while [[ $attempt -lt $max_attempts ]]; do\n        if remote curl -sf -o /dev/null \"http://127.0.0.1/health\" 2>/dev/null; then\n            echo \"Health check passed.\"\n            return 0\n        fi\n        attempt=$((attempt + 1))\n        sleep 2\n    done\n\n    echo \"WARNING: Health check did not pass after ${max_attempts} attempts.\"\n    echo \"The containers may still be starting. Check with:\"\n    echo \"  ssh $SERVER_USER@$SERVER_IP 'cd /opt/desent && docker compose logs'\"\n    return 1\n}\n\n# ─── Main ────────────────────────────────────────────────────────────\nmain() {\n    banner\n    check_deps\n\n    # Prompt for connection details\n    printf \"  ${BOLD}Server connection details${RESET}\\n\\n\"\n\n    read -rp \"  IP address: \" SERVER_IP\n    [[ -z \"$SERVER_IP\" ]] && fatal \"IP address is required\"\n\n    read -rp \"  SSH login:  \" SERVER_USER\n    [[ -z \"$SERVER_USER\" ]] && fatal \"SSH login is required\"\n\n    printf \"  SSH password: \"\n    read -rs SERVER_PASS\n    echo \"\"\n    [[ -z \"$SERVER_PASS\" ]] && fatal \"SSH password is required\"\n\n    export SERVER_IP SERVER_USER SERVER_PASS\n\n    echo \"\"\n    printf \"  ${DIM}Deploying to ${BOLD}%s${RESET}${DIM} as ${BOLD}%s${RESET}\\n\" \"$SERVER_IP\" \"$SERVER_USER\"\n    echo \"\"\n\n    # Run steps\n    step \"Testing SSH connection\"     do_test_ssh\n    step \"Installing Docker\"          do_install_docker\n    step \"Building Docker images\"     do_build_images\n    step \"Transferring images\"        do_transfer_images\n    step \"Generating config\"          do_generate_config\n    step \"Deploying containers\"       do_deploy\n    step \"Verifying deployment\"       do_verify\n\n    # Done\n    echo \"\"\n    printf \"  ${GREEN}${BOLD}${TICK} Deploy complete!${RESET}\\n\"\n    echo \"\"\n    printf \"  ${BOLD}Web app:${RESET}     http://%s\\n\" \"$SERVER_IP\"\n    printf \"  ${BOLD}RTMP ingest:${RESET} rtmp://%s:1935/live/live\\n\" \"$SERVER_IP\"\n    printf \"  ${BOLD}Traefik:${RESET}     http://%s:8080\\n\" \"$SERVER_IP\"\n    echo \"\"\n    printf \"  ${DIM}Stream with OBS → rtmp://%s:1935/live/live${RESET}\\n\" \"$SERVER_IP\"\n    printf \"  ${DIM}Watch at → http://%s${RESET}\\n\" \"$SERVER_IP\"\n    echo \"\"\n}\n\nmain \"$@\"\n",
