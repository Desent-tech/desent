вҶ’  async get<T>(path: string, params?: Record<string, string>): Promise<T> {\n    61вҶ’    let url = path\n    62вҶ’    if (params) {\n    63вҶ’      const search = new URLSearchParams(params).toString()\n    64вҶ’      if (search) url += `?${search}`\n    65вҶ’    }\n    66вҶ’    return this.request<T>(\"GET\", url)\n    67вҶ’  }\n    68вҶ’\n    69вҶ’  async post<T>(path: string, body?: unknown): Promise<T> {\n    70вҶ’    return this.request<T>(\"POST\", path, body)\n    71вҶ’  }\n    72вҶ’\n    73вҶ’  async put<T>(path: string, body?: unknown): Promise<T> {\n    74вҶ’    return this.request<T>(\"PUT\", path, body)\n    75вҶ’  }\n    76вҶ’\n    77вҶ’  async delete<T>(path: string): Promise<T> {\n    78вҶ’    return this.request<T>(\"DELETE\", path)\n    79вҶ’  }\n    80вҶ’\n    81вҶ’  // Auth\n    82вҶ’\n    83вҶ’  login(username: string, password: string): Promise<AuthResponse> {\n    84вҶ’    return this.post(\"/api/auth/login\", { username, password })\n    85вҶ’  }\n    86вҶ’\n    87вҶ’  register(username: string, password: string): Promise<AuthResponse> {\n    88вҶ’    return this.post(\"/api/auth/register\", { username, password })\n    89вҶ’  }\n    90вҶ’\n    91вҶ’  // Stream\n    92вҶ’\n    93вҶ’  getStreamStatus(): Promise<StreamStatus> {\n    94вҶ’    return this.get(\"/api/stream/status\")\n    95вҶ’  }\n    96вҶ’\n    97вҶ’  getHlsUrl(quality: string): string {\n    98вҶ’    return `${this.baseUrl}/live/${quality}/index.m3u8`\n    99вҶ’  }\n   100вҶ’\n   101вҶ’  // Chat\n   102вҶ’\n   103вҶ’  getChatSessions(limit?: number): Promise<ChatSessionsResponse> {\n   104вҶ’    const params: Record<string, string> = {}\n   105вҶ’    if (limit !== undefined) params.limit = String(limit)\n   106вҶ’    return this.get(\"/api/chat/sessions\", params)\n   107вҶ’  }\n   108вҶ’\n   109вҶ’  getChatHistory(sessionId: number, limit?: number, before?: number): Promise<ChatHistoryResponse> {\n   110вҶ’    const params: Record<string, string> = {}\n   111вҶ’    if (limit !== undefined) params.limit = String(limit)\n   112вҶ’    if (before !== undefined) params.before = String(before)\n   113вҶ’    return this.get(`/api/chat/history/${sessionId}`, params)\n   114вҶ’  }\n   115вҶ’\n   116вҶ’  getChatWsUrl(token: string): string {\n   117вҶ’    const url = new URL(this.baseUrl)\n   118вҶ’    url.protocol = url.protocol === \"https:\" ? \"wss:\" : \"ws:\"\n   119вҶ’    return `${url.origin}/ws/chat?token=${encodeURIComponent(token)}`\n   120вҶ’  }\n   121вҶ’\n   122вҶ’  // Admin\n   123вҶ’\n   124вҶ’  getAdminSettings(): Promise<AdminSettings> {\n   125вҶ’    return this.get(\"/api/admin/settings\")\n   126вҶ’  }\n   127вҶ’\n   128вҶ’  updateAdminSettings(settings: AdminSettings): Promise<AdminSettings> {\n   129вҶ’    return this.put(\"/api/admin/settings\", settings)\n   130вҶ’  }\n   131вҶ’\n   132вҶ’  getAdminUsers(): Promise<UserInfo[]> {\n   133вҶ’    return this.get(\"/api/admin/users\")\n   134вҶ’  }\n   135вҶ’\n   136вҶ’  banUser(userId: number, reason: string): Promise<void> {\n   137вҶ’    return this.post(\"/api/admin/ban\", { user_id: userId, reason })\n   138вҶ’  }\n   139вҶ’\n   140вҶ’  unbanUser(userId: number): Promise<void> {\n   141вҶ’    return this.delete(`/api/admin/ban/${userId}`)\n   142вҶ’  }\n   143вҶ’\n   144вҶ’  getAdminStats(): Promise<ServerStats> {\n   145вҶ’    return this.get(\"/api/admin/stats\")\n   146вҶ’  }\n   147вҶ’\n   148вҶ’  getAdminQualities(): Promise<QualitiesConfig> {\n   149вҶ’    return this.get(\"/api/admin/qualities\")\n   150вҶ’  }\n   151вҶ’\n   152вҶ’  updateAdminQualities(enabled: string[]): Promise<QualitiesConfig> {\n   153вҶ’    return this.put(\"/api/admin/qualities\", { enabled })\n   154вҶ’  }\n   155вҶ’}\n   156вҶ’\n   157вҶ’export const api = new ApiClient()\n   158вҶ’",
