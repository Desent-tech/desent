          "text": "     1вҶ’#!/usr/bin/env bash\n     2вҶ’set -euo pipefail\n     3вҶ’\n     4вҶ’# в”Җв”Җв”Җ Colors & Symbols в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n     5вҶ’RED='\\033[0;31m'\n     6вҶ’GREEN='\\033[0;32m'\n     7вҶ’CYAN='\\033[0;36m'\n     8вҶ’BOLD='\\033[1m'\n     9вҶ’DIM='\\033[2m'\n    10вҶ’RESET='\\033[0m'\n    11вҶ’\n    12вҶ’TICK=\"вң“\"\n    13вҶ’CROSS=\"вң—\"\n    14вҶ’SPINNER_FRAMES=(в Ӣ в ҷ в № в ё в ј в ҙ в Ұ в § в Ү в Ҹ)\n    15вҶ’\n    16вҶ’TOTAL_STEPS=7\n    17вҶ’CURRENT_STEP=0\n    18вҶ’LOG_FILE=\"/tmp/deploy-desent-$$.log\"\n    19вҶ’DEPLOY_KEY=~/.ssh/desent_deploy\n    20вҶ’\n    21вҶ’# в”Җв”Җв”Җ Cleanup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    22вҶ’cleanup() {\n    23вҶ’    tput cnorm 2>/dev/null || true\n    24вҶ’    rm -f /tmp/deploy-compose-$$ /tmp/deploy-step-$$ /tmp/deploy-rc-$$ 2>/dev/null || true\n    25вҶ’}\n    26вҶ’trap cleanup EXIT\n    27вҶ’\n    28вҶ’# в”Җв”Җв”Җ Terminal UX в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    29вҶ’banner() {\n    30вҶ’    echo \"\"\n    31вҶ’    printf \"${BOLD}${CYAN}\"\n    32вҶ’    cat <<'ART'\n    33вҶ’     _                      _\n    34вҶ’  __| | ___  ___  ___ _ __ | |_\n    35вҶ’ / _` |/ _ \\/ __|/ _ \\ '_ \\| __|\n    36вҶ’| (_| |  __/\\__ \\  __/ | | | |_\n    37вҶ’ \\__,_|\\___||___/\\___|_| |_|\\__|\n    38вҶ’\n    39вҶ’ART\n    40вҶ’    printf \"${RESET}\"\n    41вҶ’    printf \"${DIM}  Decentralized Streaming Platform вҖ” Deploy${RESET}\\n\"\n    42вҶ’    echo \"\"\n    43вҶ’}\n    44вҶ’\n    45вҶ’fatal() {\n    46вҶ’    tput cnorm 2>/dev/null || true\n    47вҶ’    printf \"\\n  ${RED}${BOLD}Fatal:${RESET} %s\\n\\n\" \"$1\"\n    48вҶ’    exit 1\n    49вҶ’}\n    50вҶ’\n    51вҶ’# в”Җв”Җв”Җ Step runner with live collapsing output в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    52вҶ’#\n    53вҶ’# Shows a scrolling window of the last N output lines while running.\n    54вҶ’# When the step finishes, erases the log and collapses to one status line.\n    55вҶ’#\n    56вҶ’step() {\n    57вҶ’    local msg=\"$1\"\n    58вҶ’    shift\n    59вҶ’    CURRENT_STEP=$((CURRENT_STEP + 1))\n    60вҶ’\n    61вҶ’    local tmpout=\"/tmp/deploy-step-$$\"\n    62вҶ’    local rcfile=\"/tmp/deploy-rc-$$\"\n    63вҶ’    local max_visible=8\n    64вҶ’    local trunc_width\n    65вҶ’    trunc_width=$(( $(tput cols 2>/dev/null || echo 80) - 6 ))\n    66вҶ’\n    67вҶ’    > \"$tmpout\"\n    68вҶ’    rm -f \"$rcfile\"\n    69вҶ’\n    70вҶ’    # Print initial header + empty line for output area\n    71вҶ’    printf \"  ${DIM}[%d/%d]${RESET} ${CYAN}%s${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"${SPINNER_FRAMES[0]}\" \"$msg\"\n    72вҶ’\n    73вҶ’    # Run command in background, save exit code\n    74вҶ’    ( set +e; \"$@\" >> \"$tmpout\" 2>&1; echo \"$?\" > \"$rcfile\" ) &\n    75вҶ’    local cmd_pid=$!\n    76вҶ’\n    77вҶ’    tput civis 2>/dev/null || true\n    78вҶ’\n    79вҶ’    local prev_lines=0\n    80вҶ’    local spin_idx=0\n    81вҶ’\n    82вҶ’    while kill -0 \"$cmd_pid\" 2>/dev/null; do\n    83вҶ’        local spin=\"${SPINNER_FRAMES[$spin_idx]}\"\n    84вҶ’        spin_idx=$(( (spin_idx + 1) % ${#SPINNER_FRAMES[@]} ))\n    85вҶ’\n    86вҶ’        # Erase header + previously drawn output lines\n    87вҶ’        local erase=$((prev_lines + 1))\n    88вҶ’        printf \"\\033[%dA\\033[J\" \"$erase\"\n    89вҶ’\n    90вҶ’        # Redraw header with animated spinner\n    91вҶ’        printf \"  ${DIM}[%d/%d]${RESET} ${CYAN}%s${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$spin\" \"$msg\"\n    92вҶ’\n    93вҶ’        # Draw last N lines from output\n    94вҶ’        prev_lines=0\n    95вҶ’        if [[ -s \"$tmpout\" ]]; then\n    96вҶ’            while IFS= read -r line; do\n    97вҶ’                printf \"    ${DIM}%.*s${RESET}\\n\" \"$trunc_width\" \"$line\"\n    98вҶ’                prev_lines=$((prev_lines + 1))\n    99вҶ’            done < <(tail -n \"$max_visible\" \"$tmpout\")\n   100вҶ’        fi\n   101вҶ’\n   102вҶ’        sleep 0.1\n   103вҶ’    done\n   104вҶ’    wait \"$cmd_pid\" 2>/dev/null || true\n   105вҶ’\n   106вҶ’    # Erase everything (header + output)\n   107вҶ’    printf \"\\033[%dA\\033[J\" $((prev_lines + 1))\n   108вҶ’\n   109вҶ’    tput cnorm 2>/dev/null || true\n   110вҶ’\n   111вҶ’    local rc\n   112вҶ’    rc=$(cat \"$rcfile\" 2>/dev/null || echo 1)\n   113вҶ’\n   114вҶ’    if [[ \"$rc\" -eq 0 ]]; then\n   115вҶ’        printf \"  ${DIM}[%d/%d]${RESET} ${GREEN}${TICK}${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$msg\"\n   116вҶ’    else\n   117вҶ’        printf \"  ${DIM}[%d/%d]${RESET} ${RED}${CROSS}${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$msg\"\n   118вҶ’        echo \"\"\n   119вҶ’        printf \"  ${RED}${BOLD}Error:${RESET} Step failed. Last 20 lines:\\n\\n\"\n   120вҶ’        tail -20 \"$tmpout\" | sed 's/^/    /'\n   121вҶ’        echo \"\"\n   122вҶ’        printf \"  ${DIM}Full log: %s${RESET}\\n\" \"$LOG_FILE\"\n   123вҶ’        cat \"$tmpout\" >> \"$LOG_FILE\"\n   124вҶ’        exit 1\n   125вҶ’    fi\n   126вҶ’\n   127вҶ’    cat \"$tmpout\" >> \"$LOG_FILE\"\n   128вҶ’    rm -f \"$tmpout\" \"$rcfile\"\n   129вҶ’}\n   130вҶ’\n   131вҶ’# в”Җв”Җв”Җ Prerequisite checks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   132вҶ’check_deps() {\n   133вҶ’    if ! command -v docker &>/dev/null; then\n   134вҶ’        printf \"  ${RED}${BOLD}Missing dependency:${RESET} docker\\n\\n\"\n   135вҶ’        printf \"  Install Docker: https://docs.docker.com/get-docker/\\n\\n\"\n   136вҶ’        exit 1\n   137вҶ’    fi\n   138вҶ’}\n   139вҶ’\n   140вҶ’# в”Җв”Җв”Җ Remote helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   141вҶ’remote() {\n   142вҶ’    $SSH_CMD \"$@\"\n   143вҶ’}\n   144вҶ’\n   145вҶ’remote_scp() {\n   146вҶ’    scp -i \"$DEPLOY_KEY\" -o StrictHostKeyChecking=no -o LogLevel=ERROR -o BatchMode=yes \"$@\"\n   147вҶ’}\n   148вҶ’\n   149вҶ’# в”Җв”Җв”Җ Step implementations в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   150вҶ’\n   151вҶ’DOCKER_OK=false\n   152вҶ’\n   153вҶ’do_check_docker() {\n   154вҶ’    remote bash -s <<'SCRIPT'\n   155вҶ’if ! command -v docker &>/dev/null; then\n   156вҶ’    echo \"NOT_INSTALLED\"\n   157вҶ’    exit 0\n   158вҶ’fi\n   159вҶ’\n   160вҶ’echo \"Found: $(docker --version)\"\n   161вҶ’\n   162вҶ’# Check Docker API version вҖ” Traefik v3 needs >= 1.40 (Docker 19.03+)\n   163вҶ’api_ver=$(docker version --format '{{.Server.APIVersion}}' 2>/dev/null || echo \"0.0\")\n   164вҶ’echo \"API version: $api_ver\"\n   165вҶ’\n   166вҶ’major=$(echo \"$api_ver\" | cut -d. -f1)\n   167вҶ’minor=$(echo \"$api_ver\" | cut -d. -f2)\n   168вҶ’\n   169вҶ’if [[ \"$major\" -gt 1 ]] || { [[ \"$major\" -eq 1 ]] && [[ \"$minor\" -ge 40 ]]; }; then\n   170вҶ’    echo \"DOCKER_OK\"\n   171вҶ’else\n   172вҶ’    echo \"DOCKER_OLD\"\n   173вҶ’fi\n   174вҶ’SCRIPT\n   175вҶ’}\n   176вҶ’\n   177вҶ’do_install_docker() {\n   178вҶ’    if [[ \"$DOCKER_OK\" == \"true\" ]]; then\n   179вҶ’        echo \"Docker is up to date, skipping install.\"\n   180вҶ’        return 0\n   181вҶ’    fi\n   182вҶ’\n   183вҶ’    remote bash -s <<'SCRIPT'\n   184вҶ’set -e\n   185вҶ’export DEBIAN_FRONTEND=noninteractive\n   186вҶ’\n   187вҶ’echo \"Stopping Docker if running...\"\n   188вҶ’systemctl stop docker 2>/dev/null || true\n   189вҶ’systemctl stop docker.socket 2>/dev/null || true\n   190вҶ’\n   191вҶ’echo \"Purging ALL old Docker packages...\"\n   192вҶ’apt-get purge -y docker docker-engine docker.io containerd runc \\\n   193вҶ’    docker-ce docker-ce-cli containerd.io docker-buildx-plugin \\\n   194вҶ’    docker-compose-plugin 2>/dev/null || true\n   195вҶ’apt-get autoremove -y 2>/dev/null || true\n   196вҶ’\n   197вҶ’echo \"Installing Docker via official script...\"\n   198вҶ’curl -fsSL https://get.docker.com | sh\n   199вҶ’\n   200вҶ’echo \"Starting Docker...\"\n   201вҶ’systemctl enable docker\n   202вҶ’systemctl start docker\n   203вҶ’\n   204вҶ’# Wait for daemon to be ready\n   205вҶ’sleep 2\n   206вҶ’\n   207вҶ’# Verify\n   208вҶ’echo \"Installed: $(docker --version)\"\n   209вҶ’api_ver=$(docker version --format '{{.Server.APIVersion}}' 2>/dev/null || echo \"unknown\")\n   210вҶ’echo \"API version: $api_ver\"\n   211вҶ’\n   212вҶ’# Sanity check\n   213вҶ’docker info >/dev/null 2>&1 || { echo \"ERROR: docker info failed\"; exit 1; }\n   214вҶ’echo \"Docker is ready.\"\n   215вҶ’SCRIPT\n   216вҶ’}\n   217вҶ’\n   218вҶ’do_build_images() {\n   219вҶ’    echo \"Building desent-server image...\"\n   220вҶ’    docker build --platform linux/amd64 -t desent-server .\n   221вҶ’\n   222вҶ’    echo \"Building desent-web image...\"\n   223вҶ’    docker build --platform linux/amd64 -t desent-web ./web/liches-web\n   224вҶ’}\n   225вҶ’\n   226вҶ’transfer_image() {\n   227вҶ’    local name=\"$1\"\n   228вҶ’\n   229вҶ’    echo \"Saving ${name}...\"\n   230вҶ’    local tmptar=\"/tmp/deploy-${name}-$$.tar\"\n   231вҶ’    docker save \"$name\" -o \"$tmptar\"\n   232вҶ’\n   233вҶ’    local tar_bytes\n   234вҶ’    tar_bytes=$(stat -f%z \"$tmptar\" 2>/dev/null || stat -c%s \"$tmptar\" 2>/dev/null)\n   235вҶ’    local tar_mb=$(( tar_bytes / 1024 / 1024 ))\n   236вҶ’\n   237вҶ’    echo \"Uploading ${name} (${tar_mb}MB)...\"\n   238вҶ’\n   239вҶ’    # Pipe in 4MB chunks, report progress to stderr (shows in step log)\n   240вҶ’    local bs=4194304\n   241вҶ’    local blocks=$(( (tar_bytes + bs - 1) / bs ))\n   242вҶ’    local i=0\n   243вҶ’\n   244вҶ’    (\n   245вҶ’        while [[ $i -lt $blocks ]]; do\n   246вҶ’            dd if=\"$tmptar\" bs=$bs skip=$i count=1 2>/dev/null\n   247вҶ’            i=$((i + 1))\n   248вҶ’            local pct=$((i * 100 / blocks))\n   249вҶ’            [[ $pct -gt 100 ]] && pct=100\n   250вҶ’            echo \"  ${name}: ${pct}% ($((i * bs / 1024 / 1024))/${tar_mb}MB)\" >&2\n   251вҶ’        done\n   252вҶ’    ) | $SSH_CMD \"docker load\"\n   253вҶ’\n   254вҶ’    rm -f \"$tmptar\"\n   255вҶ’    echo \"${name} loaded.\"\n   256вҶ’}\n   257вҶ’\n   258вҶ’do_transfer_images() {\n   259вҶ’    transfer_image \"desent-server\"\n   260вҶ’    transfer_image \"desent-web\"\n   261вҶ’}\n   262вҶ’\n   263вҶ’do_generate_config() {\n   264вҶ’    local jwt_secret\n   265вҶ’    jwt_secret=$(openssl rand -hex 32)\n   266вҶ’\n   267вҶ’    cat > /tmp/deploy-compose-$$ <<YAML\n   268вҶ’services:\n   269вҶ’  traefik:\n   270вҶ’    image: traefik:v3.6.10\n   271вҶ’    command:\n   272вҶ’      - --providers.docker=true\n   273вҶ’      - --providers.docker.exposedbydefault=false\n   274вҶ’      - --entrypoints.web.address=:80\n   275вҶ’    ports:\n   276вҶ’      - \"80:80\"\n   277вҶ’    volumes:\n   278вҶ’      - /var/run/docker.sock:/var/run/docker.sock:ro\n   279вҶ’    restart: unless-stopped\n   280вҶ’\n   281вҶ’  server:\n   282вҶ’    image: desent-server:latest\n   283вҶ’    labels:\n   284вҶ’      - traefik.enable=true\n   285вҶ’      - \"traefik.http.routers.server.rule=PathPrefix(\\`/api\\`) || PathPrefix(\\`/ws\\`) || PathPrefix(\\`/live\\`) || PathPrefix(\\`/health\\`) || PathPrefix(\\`/static\\`)\"\n   286вҶ’      - traefik.http.routers.server.entrypoints=web\n   287вҶ’      - traefik.http.services.server.loadbalancer.server.port=8080\n   288вҶ’    ports:\n   289вҶ’      - \"1935:1935\"\n   290вҶ’    environment:\n   291вҶ’      - JWT_SECRET=${jwt_secret}\n   292вҶ’      - HLS_CACHE_MB=512\n   293вҶ’      - STREAM_KEY=live\n   294вҶ’      - DB_PATH=/data/desent.db\n   295вҶ’      - HLS_DIR=/tmp/hls\n   296вҶ’      - HTTP_ADDR=:8080\n   297вҶ’      - RTMP_ADDR=0.0.0.0:1935\n   298вҶ’    volumes:\n   299вҶ’      - db-data:/data\n   300вҶ’    restart: unless-stopped\n   301вҶ’\n   302вҶ’  web:\n   303вҶ’    image: desent-web:latest\n   304вҶ’    labels:\n   305вҶ’      - traefik.enable=true\n   306вҶ’      - \"traefik.http.routers.web.rule=PathPrefix(\\`/\\`)\"\n   307вҶ’      - traefik.http.routers.web.entrypoints=web\n   308вҶ’      - traefik.http.routers.web.priority=1\n   309вҶ’      - traefik.http.services.web.loadbalancer.server.port=3000\n   310вҶ’    depends_on:\n   311вҶ’      - server\n   312вҶ’    restart: unless-stopped\n   313вҶ’\n   314вҶ’volumes:\n   315вҶ’  db-data:\n   316вҶ’YAML\n   317вҶ’\n   318вҶ’    echo \"Creating /opt/desent on server...\"\n   319вҶ’    remote mkdir -p /opt/desent\n   320вҶ’\n   321вҶ’    echo \"Uploading docker-compose.yml...\"\n   322вҶ’    remote_scp /tmp/deploy-compose-$$ \"${SSH_TARGET}:/opt/desent/docker-compose.yml\"\n   323вҶ’\n   324вҶ’    rm -f /tmp/deploy-compose-$$\n   325вҶ’    echo \"Config deployed.\"\n   326вҶ’}\n   327вҶ’\n   328вҶ’do_deploy() {\n   329вҶ’    remote bash -s <<'SCRIPT'\n   330вҶ’cd /opt/desent\n   331вҶ’\n   332вҶ’echo \"Stopping old containers...\"\n   333вҶ’docker compose down 2>/dev/null || true\n   334вҶ’\n   335вҶ’echo \"Starting containers...\"\n   336вҶ’docker compose up -d\n   337вҶ’\n   338вҶ’echo \"Containers running:\"\n   339вҶ’docker compose ps\n   340вҶ’SCRIPT\n   341вҶ’}\n   342вҶ’\n   343вҶ’do_verify() {\n   344вҶ’    local max_attempts=20\n   345вҶ’    local attempt=0\n   346вҶ’\n   347вҶ’    echo \"Waiting for services to start...\"\n   348вҶ’    while [[ $attempt -lt $max_attempts ]]; do\n   349вҶ’        # Try via Traefik (port 80)\n   350вҶ’        if remote curl -sf -o /dev/null \"http://127.0.0.1/health\" 2>/dev/null; then\n   351вҶ’            