          "text": "     1вҶ’package ingest\n     2вҶ’\n     3вҶ’import (\n     4вҶ’\t\"bufio\"\n     5вҶ’\t\"context\"\n     6вҶ’\t\"log/slog\"\n     7вҶ’\t\"os/exec\"\n     8вҶ’\t\"sync\"\n     9вҶ’\t\"syscall\"\n    10вҶ’\t\"time\"\n    11вҶ’)\n    12вҶ’\n    13вҶ’type Config struct {\n    14вҶ’\tFFmpegPath  string\n    15вҶ’\tRTMPAddr    string\n    16вҶ’\tStreamKey   string\n    17вҶ’\tHLSDir      string\n    18вҶ’\tOnStreamEnd func() // called after FFmpeg exits (stream ends)\n    19вҶ’}\n    20вҶ’\n    21вҶ’type Manager struct {\n    22вҶ’\tcfg          Config\n    23вҶ’\tmu           sync.Mutex\n    24вҶ’\tcmd          *exec.Cmd\n    25вҶ’\trunning      bool\n    26вҶ’\tqualities    []Quality\n    27вҶ’\tfpsOverrides map[string]int\n    28вҶ’\tstartedAt    time.Time\n    29вҶ’}\n    30вҶ’\n    31вҶ’func NewManager(cfg Config) *Manager {\n    32вҶ’\treturn &Manager{\n    33вҶ’\t\tcfg:          cfg,\n    34вҶ’\t\tqualities:    FilterQualities(DefaultQualities),\n    35вҶ’\t\tfpsOverrides: DefaultFPSOverrides(),\n    36вҶ’\t}\n    37вҶ’}\n    38вҶ’\n    39вҶ’// SetFPSOverrides merges per-quality FPS overrides. Only HD qualities (720p+)\n    40вҶ’// with values 30 or 60 are accepted.\n    41вҶ’func (m *Manager) SetFPSOverrides(overrides map[string]int) {\n    42вҶ’\tm.mu.Lock()\n    43вҶ’\tfor _, q := range AllQualities {\n    44вҶ’\t\tif !q.IsHD() {\n    45вҶ’\t\t\tcontinue\n    46вҶ’\t\t}\n    47вҶ’\t\tif fps, ok := overrides[q.Name]; ok && (fps == 30 || fps == 60) {\n    48вҶ’\t\t\tm.fpsOverrides[q.Name] = fps\n    49вҶ’\t\t}\n    50вҶ’\t}\n    51вҶ’\tm.mu.Unlock()\n    52вҶ’}\n    53вҶ’\n    54вҶ’// FPSOverrides returns a copy of the current per-quality FPS map.\n    55вҶ’func (m *Manager) FPSOverrides() map[string]int {\n    56вҶ’\tm.mu.Lock()\n    57вҶ’\tdefer m.mu.Unlock()\n    58вҶ’\tcp := make(map[string]int, len(m.fpsOverrides))\n    59вҶ’\tfor k, v := range m.fpsOverrides {\n    60вҶ’\t\tcp[k] = v\n    61вҶ’\t}\n    62вҶ’\treturn cp\n    63вҶ’}\n    64вҶ’\n    65вҶ’// QualityFPS returns the effective FPS for each enabled quality.\n    66вҶ’// HD qualities use overrides, SD qualities use their preset default.\n    67вҶ’func (m *Manager) QualityFPS() map[string]int {\n    68вҶ’\tm.mu.Lock()\n    69вҶ’\tdefer m.mu.Unlock()\n    70вҶ’\tresult := make(map[string]int, len(m.qualities))\n    71вҶ’\tfor _, q := range m.qualities {\n    72вҶ’\t\tif fps, ok := m.fpsOverrides[q.Name]; ok {\n    73вҶ’\t\t\tresult[q.Name] = fps\n    74вҶ’\t\t} else {\n    75вҶ’\t\t\tresult[q.Name] = q.FPS\n    76вҶ’\t\t}\n    77вҶ’\t}\n    78вҶ’\treturn result\n    79вҶ’}\n    80вҶ’\n    81вҶ’// SetQualities updates the enabled quality list. Never allows an empty set.\n    82вҶ’func (m *Manager) SetQualities(names []string) {\n    83вҶ’\tq := FilterQualities(names)\n    84вҶ’\tif len(q) == 0 {\n    85вҶ’\t\treturn\n    86вҶ’\t}\n    87вҶ’\tm.mu.Lock()\n    88вҶ’\tm.qualities = q\n    89вҶ’\tm.mu.Unlock()\n    90вҶ’}\n    91вҶ’\n    92вҶ’// EnabledQualities returns the names of currently enabled qualities.\n    93вҶ’func (m *Manager) EnabledQualities() []string {\n    94вҶ’\tm.mu.Lock()\n    95вҶ’\tdefer m.mu.Unlock()\n    96вҶ’\tnames := make([]string, len(m.qualities))\n    97вҶ’\tfor i, q := range m.qualities {\n    98вҶ’\t\tnames[i] = q.Name\n    99вҶ’\t}\n   100вҶ’\treturn names\n   101вҶ’}\n   102вҶ’\n   103вҶ’// Restart sends SIGTERM to the current FFmpeg process.\n   104вҶ’// The Run() loop will automatically restart it with the latest qualities.\n   105вҶ’func (m *Manager) Restart() {\n   106вҶ’\tm.mu.Lock()\n   107вҶ’\tdefer m.mu.Unlock()\n   108вҶ’\tif m.cmd != nil && m.cmd.Process != nil {\n   109вҶ’\t\tm.cmd.Process.Signal(syscall.SIGTERM)\n   110вҶ’\t}\n   111вҶ’}\n   112вҶ’\n   113вҶ’// StartedAt returns when the manager was started.\n   114вҶ’func (m *Manager) StartedAt() time.Time {\n   115вҶ’\tm.mu.Lock()\n   116вҶ’\tdefer m.mu.Unlock()\n   117вҶ’\treturn m.startedAt\n   118вҶ’}\n   119вҶ’\n   120вҶ’// Run starts the FFmpeg ingest loop. Blocks until ctx is cancelled.\n   121вҶ’// Automatically restarts FFmpeg when the stream disconnects.\n   122вҶ’func (m *Manager) Run(ctx context.Context) {\n   123вҶ’\tm.mu.Lock()\n   124вҶ’\tm.startedAt = time.Now()\n   125вҶ’\tm.mu.Unlock()\n   126вҶ’\n   127вҶ’\tfor {\n   128вҶ’\t\tselect {\n   129вҶ’\t\tcase <-ctx.Done():\n   130вҶ’\t\t\tm.stop()\n   131вҶ’\t\t\treturn\n   132вҶ’\t\tdefault:\n   133вҶ’\t\t}\n   134вҶ’\n   135вҶ’\t\tslog.Info(\"ingest: waiting for RTMP stream\", \"addr\", m.cfg.RTMPAddr, \"key\", m.cfg.StreamKey)\n   136вҶ’\t\tif err := m.runFFmpeg(ctx); err != nil {\n   137вҶ’\t\t\tif ctx.Err() != nil {\n   138вҶ’\t\t\t\treturn\n   139вҶ’\t\t\t}\n   140вҶ’\t\t\tslog.Warn(\"ingest: FFmpeg exited\", \"err\", err)\n   141вҶ’\t\t}\n   142вҶ’\n   143вҶ’\t\tselect {\n   144вҶ’\t\tcase <-ctx.Done():\n   145вҶ’\t\t\treturn\n   146вҶ’\t\tcase <-time.After(2 * time.Second):\n   147вҶ’\t\t}\n   148вҶ’\t}\n   149вҶ’}\n   150вҶ’\n   151вҶ’func (m *Manager) runFFmpeg(ctx context.Context) error {\n   152вҶ’\trtmpURL := \"rtmp://\" + m.cfg.RTMPAddr + \"/live/\" + m.cfg.StreamKey\n   153вҶ’\n   154вҶ’\t// Snapshot qualities and FPS overrides under lock\n   155вҶ’\tm.mu.Lock()\n   156вҶ’\tquals := make([]Quality, len(m.qualities))\n   157вҶ’\tcopy(quals, m.qualities)\n   158вҶ’\toverrides := make(map[string]int, len(m.fpsOverrides))\n   159вҶ’\tfor k, v := range m.fpsOverrides {\n   160вҶ’\t\toverrides[k] = v\n   161вҶ’\t}\n   162вҶ’\tm.mu.Unlock()\n   163вҶ’\n   164вҶ’\tquals = ApplyFPSOverrides(quals, overrides)\n   165вҶ’\n   166вҶ’\tcmd := exec.CommandContext(ctx, m.cfg.FFmpegPath, buildFFmpegArgs(rtmpURL, m.cfg.HLSDir, quals)...)\n   167вҶ’\tcmd.WaitDelay = 5 * time.Second\n   168вҶ’\n   169вҶ’\tstderr, err := cmd.StderrPipe()\n   170вҶ’\tif err != nil {\n   171вҶ’\t\treturn err\n   172вҶ’\t}\n   173вҶ’\n   174вҶ’\tm.mu.Lock()\n   175вҶ’\tm.cmd = cmd\n   176вҶ’\tm.running = true\n   177вҶ’\tm.mu.Unlock()\n   178вҶ’\n   179вҶ’\tif err := cmd.Start(); err != nil {\n   180вҶ’\t\tm.mu.Lock()\n   181вҶ’\t\tm.running = false\n   182вҶ’\t\tm.mu.Unlock()\n   183вҶ’\t\treturn err\n   184вҶ’\t}\n   185вҶ’\n   186вҶ’\tslog.Info(\"ingest: FFmpeg started\", \"pid\", cmd.Process.Pid, \"qualities\", qualityNames(quals))\n   187вҶ’\n   188вҶ’\tgo func() {\n   189вҶ’\t\tscanner := bufio.NewScanner(stderr)\n   190вҶ’\t\tfor scanner.Scan() {\n   191вҶ’\t\t\tslog.Debug(\"ffmpeg\", \"line\", scanner.Text())\n   192вҶ’\t\t}\n   193вҶ’\t}()\n   194вҶ’\n   195вҶ’\terr = cmd.Wait()\n   196вҶ’\n   197вҶ’\tm.mu.Lock()\n   198вҶ’\tm.running = false\n   199вҶ’\tm.mu.Unlock()\n   200вҶ’\n   201вҶ’\tif m.cfg.OnStreamEnd != nil {\n   202вҶ’\t\tm.cfg.OnStreamEnd()\n   203вҶ’\t}\n   204вҶ’\n   205вҶ’\treturn err\n   206вҶ’}\n   207вҶ’\n   208вҶ’func (m *Manager) stop() {\n   209вҶ’\tm.mu.Lock()\n   210вҶ’\tdefer m.mu.Unlock()\n   211вҶ’\tif m.cmd != nil && m.cmd.Process != nil {\n   212вҶ’\t\tm.cmd.Process.Signal(syscall.SIGTERM)\n   213вҶ’\t}\n   214вҶ’}\n   215вҶ’\n   216вҶ’// IsLive reports whether FFmpeg is currently running (stream is active).\n   217вҶ’func (m *Manager) IsLive() bool {\n   218вҶ’\tm.mu.Lock()\n   219вҶ’\tdefer m.mu.Unlock()\n   220вҶ’\treturn m.running\n   221вҶ’}\n   222вҶ’\n   223вҶ’func qualityNames(qs []Quality) []string {\n   224вҶ’\tnames := make([]string, len(qs))\n   225вҶ’\tfor i, q := range qs {\n   226вҶ’\t\tnames[i] = q.Name\n   227вҶ’\t}\n   228вҶ’\treturn names\n   229вҶ’}\n   230вҶ’",
