e checks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   104вҶ’check_deps() {\n   105вҶ’    if ! command -v docker &>/dev/null; then\n   106вҶ’        printf \"  ${RED}${BOLD}Missing dependency:${RESET} docker\\n\\n\"\n   107вҶ’        printf \"  Install Docker: https://docs.docker.com/get-docker/\\n\\n\"\n   108вҶ’        exit 1\n   109вҶ’    fi\n   110вҶ’}\n   111вҶ’\n   112вҶ’# в”Җв”Җв”Җ SSH key setup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   113вҶ’setup_ssh_key() {\n   114вҶ’    # Find existing SSH key\n   115вҶ’    for key in ~/.ssh/id_ed25519 ~/.ssh/id_rsa ~/.ssh/id_ecdsa; do\n   116вҶ’        if [[ -f \"$key\" ]]; then\n   117вҶ’            SSH_KEY=\"$key\"\n   118вҶ’            break\n   119вҶ’        fi\n   120вҶ’    done\n   121вҶ’\n   122вҶ’    # Generate if none found\n   123вҶ’    if [[ -z \"$SSH_KEY\" ]]; then\n   124вҶ’        printf \"  ${DIM}No SSH key found. Generating one...${RESET}\\n\"\n   125вҶ’        ssh-keygen -t ed25519 -f ~/.ssh/id_ed25519 -N \"\" -q\n   126вҶ’        SSH_KEY=~/.ssh/id_ed25519\n   127вҶ’        printf \"  ${GREEN}${TICK}${RESET} Created ${DIM}%s${RESET}\\n\" \"$SSH_KEY\"\n   128вҶ’    else\n   129вҶ’        printf \"  ${GREEN}${TICK}${RESET} Using SSH key ${DIM}%s${RESET}\\n\" \"$SSH_KEY\"\n   130вҶ’    fi\n   131вҶ’\n   132вҶ’    # Ensure ssh-agent is running and key is loaded (caches passphrase)\n   133вҶ’    if ! ssh-add -l &>/dev/null; then\n   134вҶ’        eval \"$(ssh-agent -s)\" >/dev/null\n   135вҶ’    fi\n   136вҶ’    if ! ssh-add -l 2>/dev/null | grep -q \"$SSH_KEY\"; then\n   137вҶ’        printf \"  ${DIM}Adding key to ssh-agent (enter passphrase if prompted):${RESET}\\n\"\n   138вҶ’        ssh-add \"$SSH_KEY\" || fatal \"Could not add SSH key to agent\"\n   139вҶ’        printf \"  ${GREEN}${TICK}${RESET} Key added to ssh-agent\\n\"\n   140вҶ’    fi\n   141вҶ’\n   142вҶ’    # Quick test: does key auth already work?\n   143вҶ’    if ssh -o BatchMode=yes -o ConnectTimeout=5 \\\n   144вҶ’        -o StrictHostKeyChecking=no -o LogLevel=ERROR \\\n   145вҶ’        \"$SERVER_USER@$SERVER_IP\" true &>/dev/null; then\n   146вҶ’        printf \"  ${GREEN}${TICK}${RESET} Key auth already works\\n\"\n   147вҶ’        return 0\n   148вҶ’    fi\n   149вҶ’\n   150вҶ’    # Copy key manually (no ssh-copy-id вҖ” it's slow and hangs)\n   151вҶ’    printf \"  ${DIM}Enter server password to copy SSH key:${RESET}\\n\"\n   152вҶ’    local pubkey\n   153вҶ’    pubkey=$(cat \"${SSH_KEY}.pub\")\n   154вҶ’    ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 \\\n   155вҶ’        \"$SERVER_USER@$SERVER_IP\" \\\n   156вҶ’        \"mkdir -p ~/.ssh && chmod 700 ~/.ssh && echo '${pubkey}' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys\"\n   157вҶ’    printf \"  ${GREEN}${TICK}${RESET} SSH key installed\\n\"\n   158вҶ’}\n   159вҶ’\n   160вҶ’# в”Җв”Җв”Җ Remote SSH helper в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   161вҶ’# No -i flag вҖ” ssh-agent provides the key (passphrase already cached)\n   162вҶ’SSH_OPTS=(-o StrictHostKeyChecking=no -o LogLevel=ERROR -o ConnectTimeout=10)\n   163вҶ’\n   164вҶ’remote() {\n   165вҶ’    ssh \"${SSH_OPTS[@]}\" \"$SERVER_USER@$SERVER_IP\" \"$@\"\n   166вҶ’}\n   167вҶ’\n   168вҶ’remote_scp() {\n   169вҶ’    scp \"${SSH_OPTS[@]}\" \"$@\"\n   170вҶ’}\n   171вҶ’\n   172вҶ’# в”Җв”Җв”Җ Step implementations в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   173вҶ’\n   174вҶ’do_test_ssh() {\n   175вҶ’    remote echo \"SSH connection OK\"\n   176вҶ’}\n   177вҶ’\n   178вҶ’do_install_docker() {\n   179вҶ’    remote bash -s <<'SCRIPT'\n   180вҶ’if command -v docker &>/dev/null; then\n   181вҶ’    echo \"Docker already installed: $(docker --version)\"\n   182вҶ’    systemctl start docker 2>/dev/null || service docker start 2>/dev/null || true\n   183вҶ’    exit 0\n   184вҶ’fi\n   185вҶ’\n   186вҶ’echo \"Installing Docker...\"\n   187вҶ’export DEBIAN_FRONTEND=noninteractive\n   188вҶ’\n   189вҶ’curl -fsSL https://get.docker.com | sh\n   190вҶ’\n   191вҶ’systemctl enable docker 2>/dev/null || true\n   192вҶ’systemctl start docker 2>/dev/null || service docker start 2>/dev/null || true\n   193вҶ’\n   194вҶ’usermod -aG docker \"$(whoami)\" 2>/dev/null || true\n   195вҶ’\n   196вҶ’echo \"Docker installed: $(docker --version)\"\n   197вҶ’SCRIPT\n   198вҶ’}\n   199вҶ’\n   200вҶ’do_build_images() {\n   201вҶ’    echo \"Building desent-server image...\"\n   202вҶ’    docker build --platform linux/amd64 -t desent-server .\n   203вҶ’\n   204вҶ’    echo \"Building desent-web image...\"\n   205вҶ’    docker build --platform linux/amd64 -t desent-web ./web/liches-web\n   206вҶ’}\n   207вҶ’\n   208вҶ’do_transfer_images() {\n   209вҶ’    echo \"Saving and transferring desent-server...\"\n   210вҶ’    docker save desent-server | ssh \"${SSH_OPTS[@]}\" \"$SERVER_USER@$SERVER_IP\" \"docker load\"\n   211вҶ’\n   212вҶ’    echo \"Saving and transferring desent-web...\"\n   213вҶ’    docker save desent-web | ssh \"${SSH_OPTS[@]}\" \"$SERVER_USER@$SERVER_IP\" \"docker load\"\n   214вҶ’}\n   215вҶ’\n   216вҶ’do_generate_config() {\n   217вҶ’    local jwt_secret\n   218вҶ’    jwt_secret=$(openssl rand -hex 32)\n   219вҶ’\n   220вҶ’    cat > /tmp/docker-compose.prod.yml.$$ <<YAML\n   221вҶ’services:\n   222вҶ’  traefik:\n   223вҶ’    image: traefik:v3.3\n   224вҶ’    command:\n   225вҶ’      - --api.insecure=true\n   226вҶ’      - --providers.docker=true\n   227вҶ’      - --providers.docker.exposedbydefault=false\n   228вҶ’      - --entrypoints.web.address=:80\n   229вҶ’    ports:\n   230вҶ’      - \"80:80\"\n   231вҶ’      - \"8080:8080\"\n   232вҶ’    volumes:\n   233вҶ’      - /var/run/docker.sock:/var/run/docker.sock:ro\n   234вҶ’    restart: unless-stopped\n   235вҶ’\n   236вҶ’  server:\n   237вҶ’    image: desent-server:latest\n   238вҶ’    labels:\n   239вҶ’      - traefik.enable=true\n   240вҶ’      - \"traefik.http.routers.api.rule=PathPrefix(\\`/api\\`) || PathPrefix(\\`/ws\\`) || PathPrefix(\\`/live\\`) || PathPrefix(\\`/health\\`)\"\n   241вҶ’      - traefik.http.routers.api.entrypoints=web\n   242вҶ’      - traefik.http.services.api.loadbalancer.server.port=8080\n   243вҶ’    ports:\n   244вҶ’      - \"1935:1935\"\n   245вҶ’    environment:\n   246вҶ’      - JWT_SECRET=${jwt_secret}\n   247вҶ’      - STREAM_KEY=live\n   248вҶ’      - DB_PATH=/data/desent.db\n   249вҶ’      - HLS_DIR=/tmp/hls\n   250вҶ’      - HTTP_ADDR=:8080\n   251вҶ’      - RTMP_ADDR=0.0.0.0:1935\n   252вҶ’    volumes:\n   253вҶ’      - db-data:/data\n   254вҶ’    restart: unless-stopped\n   255вҶ’\n   256вҶ’  web:\n   257вҶ’    image: desent-web:latest\n   258вҶ’    labels:\n   259вҶ’      - traefik.enable=true\n   260вҶ’      - \"traefik.http.routers.web.rule=PathPrefix(\\`/\\`)\"\n   261вҶ’      - traefik.http.routers.web.entrypoints=web\n   262вҶ’      - traefik.http.routers.web.priority=1\n   263вҶ’      - traefik.http.services.web.loadbalancer.server.port=3000\n   264вҶ’    environment:\n   265вҶ’      - NEXT_PUBLIC_BACKEND_URL=http://${SERVER_IP}\n   266вҶ’    depends_on:\n   267вҶ’      - server\n   268вҶ’    restart: unless-stopped\n   269вҶ’\n   270вҶ’volumes:\n   271вҶ’  db-data:\n   272вҶ’YAML\n   273вҶ’\n   274вҶ’    remote mkdir -p /opt/desent\n   275вҶ’\n   276вҶ’    remote_scp /tmp/docker-compose.prod.yml.$$ \"$SERVER_USER@$SERVER_IP:/opt/desent/docker-compose.yml\"\n   277вҶ’\n   278вҶ’    rm -f /tmp/docker-compose.prod.yml.$$\n   279вҶ’}\n   280вҶ’\n   281вҶ’do_deploy() {\n   282вҶ’    remote bash -s <<'SCRIPT'\n   283вҶ’cd /opt/desent\n   284вҶ’\n   285вҶ’docker compose down 2>/dev/null || true\n   286вҶ’\n   287вҶ’docker compose up -d\n   288вҶ’\n   289вҶ’echo \"Containers started.\"\n   290вҶ’docker compose ps\n   291вҶ’SCRIPT\n   292вҶ’}\n   293вҶ’\n   294вҶ’do_verify() {\n   295вҶ’    local max_attempts=30\n   296вҶ’    local attempt=0\n   297вҶ’\n   298вҶ’    echo \"Waiting for server to become healthy...\"\n   299вҶ’    while [[ $attempt -lt $max_attempts ]]; do\n   300вҶ’        if remote curl -sf -o /dev/null \"http://127.0.0.1/health\" 2>/dev/null; then\n   301вҶ’            echo \"Health check passed.\"\n   302вҶ’            return 0\n   303вҶ’        fi\n   304вҶ’        attempt=$((attempt + 1))\n   305вҶ’        sleep 2\n   306вҶ’    done\n   307вҶ’\n   308вҶ’    echo \"WARNING: Health check did not pass after ${max_attempts} attempts.\"\n   309вҶ’    echo \"The containers may still be starting. Check with:\"\n   310вҶ’    echo \"  ssh $SERVER_USER@$SERVER_IP 'cd /opt/desent && docker compose logs'\"\n   311вҶ’    return 1\n   312вҶ’}\n   313вҶ’\n   314вҶ’# в”Җв”Җв”Җ Main в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   315вҶ’main() {\n   316вҶ’    banner\n   317вҶ’    check_deps\n   318вҶ’\n   319вҶ’    # Prompt for connection details\n   320вҶ’    printf \"  ${BOLD}Server connection details${RESET}\\n\\n\"\n   321вҶ’\n   322вҶ’    read -rp \"  IP address: \" SERVER_IP\n   323вҶ’    [[ -z \"$SERVER_IP\" ]] && fatal \"IP address is required\"\n   324вҶ’\n   325вҶ’    read -rp \"  SSH login:  \" SERVER_USER\n   326вҶ’    [[ -z \"$SERVER_USER\" ]] && fatal \"SSH login is required\"\n   327вҶ’\n   328вҶ’    export SERVER_IP SERVER_USER\n   329вҶ’\n   330вҶ’    # Setup SSH key auth (prompts for password once via ssh-copy-id)\n   331вҶ’    setup_ssh_key\n   332вҶ’\n   333вҶ’    printf \"  ${DIM}Deploying to ${BOLD}%s${RESET}${DIM} as ${BOLD}%s${RESET}\\n\" \"$SERVER_IP\" \"$SERVER_USER\"\n   334вҶ’    echo \"\"\n   335вҶ’\n   336вҶ’    # Run steps\n   337вҶ’    step \"Testing SSH connection\"     do_test_ssh\n   338вҶ’    step \"Installing Docker\"          do_install_docker\n   339вҶ’    step \"Building Docker images\"     do_build_images\n   340вҶ’    step \"Transferring images\"        do_transfer_images\n   341вҶ’    step \"Generating config\"          do_generate_config\n   342вҶ’    step \"Deploying containers\"       do_deploy\n   343вҶ’    step \"Verifying deployment\"       do_verify\n   344вҶ’\n   345вҶ’    # Done\n   346вҶ’    echo \"\"\n   347вҶ’    printf \"  ${GREEN}${BOLD}${TICK} Deploy complete!${RESET}\\n\"\n   348вҶ’    echo \"\"\n   349вҶ’    printf \"  ${BOLD}Web app:${RESET}     http://%s\\n\" \"$SERVER_IP\"\n   350вҶ’    printf \"  ${BOLD}RTMP ingest:${RESET} rtmp://%s:1935/live/live\\n\" \"$SERVER_IP\"\n   351вҶ’    printf \"  ${BOLD}Traefik:${RESET}     http://%s:8080\\n\" \"$SERVER_IP\"\n   352вҶ’    echo \"\"\n   353вҶ’    printf \"  ${DIM}Stream with OBS вҶ’ rtmp://%s:1935/live/live${RESET}\\n\" \"$SERVER_IP\"\n   354вҶ’    printf \"  ${DIM}Watch at вҶ’ http://%s${RESET}\\n\" \"$SERVER_IP\"\n   355вҶ’    echo \"\"\n   356вҶ’}\n   357вҶ’\n   358вҶ’main \"$@\"\n   359вҶ’",
