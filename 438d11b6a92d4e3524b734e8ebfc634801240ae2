          "text": "     1вҶ’#!/usr/bin/env bash\n     2вҶ’set -euo pipefail\n     3вҶ’\n     4вҶ’# в”Җв”Җв”Җ Colors & Symbols в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n     5вҶ’RED='\\033[0;31m'\n     6вҶ’GREEN='\\033[0;32m'\n     7вҶ’CYAN='\\033[0;36m'\n     8вҶ’BOLD='\\033[1m'\n     9вҶ’DIM='\\033[2m'\n    10вҶ’RESET='\\033[0m'\n    11вҶ’\n    12вҶ’TICK=\"вң“\"\n    13вҶ’CROSS=\"вң—\"\n    14вҶ’SPINNER_FRAMES=(в Ӣ в ҷ в № в ё в ј в ҙ в Ұ в § в Ү в Ҹ)\n    15вҶ’\n    16вҶ’TOTAL_STEPS=6\n    17вҶ’CURRENT_STEP=0\n    18вҶ’LOG_FILE=\"/tmp/deploy-desent-$$.log\"\n    19вҶ’DEPLOY_KEY=~/.ssh/desent_deploy\n    20вҶ’\n    21вҶ’# в”Җв”Җв”Җ Cleanup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    22вҶ’cleanup() {\n    23вҶ’    tput cnorm 2>/dev/null || true\n    24вҶ’    rm -f /tmp/deploy-compose-$$ /tmp/deploy-step-$$ /tmp/deploy-rc-$$ 2>/dev/null || true\n    25вҶ’}\n    26вҶ’trap cleanup EXIT\n    27вҶ’\n    28вҶ’# в”Җв”Җв”Җ Terminal UX в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    29вҶ’banner() {\n    30вҶ’    echo \"\"\n    31вҶ’    printf \"${BOLD}${CYAN}\"\n    32вҶ’    cat <<'ART'\n    33вҶ’     _                      _\n    34вҶ’  __| | ___  ___  ___ _ __ | |_\n    35вҶ’ / _` |/ _ \\/ __|/ _ \\ '_ \\| __|\n    36вҶ’| (_| |  __/\\__ \\  __/ | | | |_\n    37вҶ’ \\__,_|\\___||___/\\___|_| |_|\\__|\n    38вҶ’\n    39вҶ’ART\n    40вҶ’    printf \"${RESET}\"\n    41вҶ’    printf \"${DIM}  Decentralized Streaming Platform вҖ” Deploy${RESET}\\n\"\n    42вҶ’    echo \"\"\n    43вҶ’}\n    44вҶ’\n    45вҶ’fatal() {\n    46вҶ’    tput cnorm 2>/dev/null || true\n    47вҶ’    printf \"\\n  ${RED}${BOLD}Fatal:${RESET} %s\\n\\n\" \"$1\"\n    48вҶ’    exit 1\n    49вҶ’}\n    50вҶ’\n    51вҶ’# в”Җв”Җв”Җ Step runner with live collapsing output в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n    52вҶ’#\n    53вҶ’# Shows a scrolling window of the last N output lines while running.\n    54вҶ’# When the step finishes, erases the log and collapses to one status line.\n    55вҶ’#\n    56вҶ’step() {\n    57вҶ’    local msg=\"$1\"\n    58вҶ’    shift\n    59вҶ’    CURRENT_STEP=$((CURRENT_STEP + 1))\n    60вҶ’\n    61вҶ’    local tmpout=\"/tmp/deploy-step-$$\"\n    62вҶ’    local rcfile=\"/tmp/deploy-rc-$$\"\n    63вҶ’    local max_visible=8\n    64вҶ’    local trunc_width\n    65вҶ’    trunc_width=$(( $(tput cols 2>/dev/null || echo 80) - 6 ))\n    66вҶ’\n    67вҶ’    > \"$tmpout\"\n    68вҶ’    rm -f \"$rcfile\"\n    69вҶ’\n    70вҶ’    # Print initial header + empty line for output area\n    71вҶ’    printf \"  ${DIM}[%d/%d]${RESET} ${CYAN}%s${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"${SPINNER_FRAMES[0]}\" \"$msg\"\n    72вҶ’\n    73вҶ’    # Run command in background, save exit code\n    74вҶ’    ( set +e; \"$@\" >> \"$tmpout\" 2>&1; echo \"$?\" > \"$rcfile\" ) &\n    75вҶ’    local cmd_pid=$!\n    76вҶ’\n    77вҶ’    tput civis 2>/dev/null || true\n    78вҶ’\n    79вҶ’    local prev_lines=0\n    80вҶ’    local spin_idx=0\n    81вҶ’\n    82вҶ’    while kill -0 \"$cmd_pid\" 2>/dev/null; do\n    83вҶ’        local spin=\"${SPINNER_FRAMES[$spin_idx]}\"\n    84вҶ’        spin_idx=$(( (spin_idx + 1) % ${#SPINNER_FRAMES[@]} ))\n    85вҶ’\n    86вҶ’        # Erase header + previously drawn output lines\n    87вҶ’        local erase=$((prev_lines + 1))\n    88вҶ’        printf \"\\033[%dA\\033[J\" \"$erase\"\n    89вҶ’\n    90вҶ’        # Redraw header with animated spinner\n    91вҶ’        printf \"  ${DIM}[%d/%d]${RESET} ${CYAN}%s${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$spin\" \"$msg\"\n    92вҶ’\n    93вҶ’        # Draw last N lines from output\n    94вҶ’        prev_lines=0\n    95вҶ’        if [[ -s \"$tmpout\" ]]; then\n    96вҶ’            while IFS= read -r line; do\n    97вҶ’                printf \"    ${DIM}%.*s${RESET}\\n\" \"$trunc_width\" \"$line\"\n    98вҶ’                prev_lines=$((prev_lines + 1))\n    99вҶ’            done < <(tail -n \"$max_visible\" \"$tmpout\")\n   100вҶ’        fi\n   101вҶ’\n   102вҶ’        sleep 0.1\n   103вҶ’    done\n   104вҶ’    wait \"$cmd_pid\" 2>/dev/null || true\n   105вҶ’\n   106вҶ’    # Erase everything (header + output)\n   107вҶ’    printf \"\\033[%dA\\033[J\" $((prev_lines + 1))\n   108вҶ’\n   109вҶ’    tput cnorm 2>/dev/null || true\n   110вҶ’\n   111вҶ’    local rc\n   112вҶ’    rc=$(cat \"$rcfile\" 2>/dev/null || echo 1)\n   113вҶ’\n   114вҶ’    if [[ \"$rc\" -eq 0 ]]; then\n   115вҶ’        printf \"  ${DIM}[%d/%d]${RESET} ${GREEN}${TICK}${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$msg\"\n   116вҶ’    else\n   117вҶ’        printf \"  ${DIM}[%d/%d]${RESET} ${RED}${CROSS}${RESET} %s\\n\" \"$CURRENT_STEP\" \"$TOTAL_STEPS\" \"$msg\"\n   118вҶ’        echo \"\"\n   119вҶ’        printf \"  ${RED}${BOLD}Error:${RESET} Step failed. Last 20 lines:\\n\\n\"\n   120вҶ’        tail -20 \"$tmpout\" | sed 's/^/    /'\n   121вҶ’        echo \"\"\n   122вҶ’        printf \"  ${DIM}Full log: %s${RESET}\\n\" \"$LOG_FILE\"\n   123вҶ’        cat \"$tmpout\" >> \"$LOG_FILE\"\n   124вҶ’        exit 1\n   125вҶ’    fi\n   126вҶ’\n   127вҶ’    cat \"$tmpout\" >> \"$LOG_FILE\"\n   128вҶ’    rm -f \"$tmpout\" \"$rcfile\"\n   129вҶ’}\n   130вҶ’\n   131вҶ’# в”Җв”Җв”Җ Prerequisite checks в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   132вҶ’check_deps() {\n   133вҶ’    if ! command -v docker &>/dev/null; then\n   134вҶ’        printf \"  ${RED}${BOLD}Missing dependency:${RESET} docker\\n\\n\"\n   135вҶ’        printf \"  Install Docker: https://docs.docker.com/get-docker/\\n\\n\"\n   136вҶ’        exit 1\n   137вҶ’    fi\n   138вҶ’}\n   139вҶ’\n   140вҶ’# в”Җв”Җв”Җ Remote helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   141вҶ’remote() {\n   142вҶ’    $SSH_CMD \"$@\"\n   143вҶ’}\n   144вҶ’\n   145вҶ’remote_scp() {\n   146вҶ’    scp -i \"$DEPLOY_KEY\" -o StrictHostKeyChecking=no -o LogLevel=ERROR -o BatchMode=yes \"$@\"\n   147вҶ’}\n   148вҶ’\n   149вҶ’# в”Җв”Җв”Җ Step implementations в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n   150вҶ’\n   151вҶ’do_install_docker() {\n   152вҶ’    remote bash -s <<'SCRIPT'\n   153вҶ’if command -v docker &>/dev/null; then\n   154вҶ’    echo \"Docker already installed: $(docker --version)\"\n   155вҶ’    systemctl start docker 2>/dev/null || service docker start 2>/dev/null || true\n   156вҶ’    exit 0\n   157вҶ’fi\n   158вҶ’\n   159вҶ’echo \"Installing Docker...\"\n   160вҶ’export DEBIAN_FRONTEND=noninteractive\n   161вҶ’\n   162вҶ’curl -fsSL https://get.docker.com | sh\n   163вҶ’\n   164вҶ’systemctl enable docker 2>/dev/null || true\n   165вҶ’systemctl start docker 2>/dev/null || service docker start 2>/dev/null || true\n   166вҶ’\n   167вҶ’usermod -aG docker \"$(whoami)\" 2>/dev/null || true\n   168вҶ’\n   169вҶ’echo \"Docker installed: $(docker --version)\"\n   170вҶ’SCRIPT\n   171вҶ’}\n   172вҶ’\n   173вҶ’do_build_images() {\n   174вҶ’    echo \"Building desent-server image...\"\n   175вҶ’    docker build --platform linux/amd64 -t desent-server .\n   176вҶ’\n   177вҶ’    echo \"Building desent-web image...\"\n   178вҶ’    docker build --platform linux/amd64 -t desent-web ./web/liches-web\n   179вҶ’}\n   180вҶ’\n   181вҶ’transfer_image() {\n   182вҶ’    local name=\"$1\"\n   183вҶ’\n   184вҶ’    echo \"Saving ${name}...\"\n   185вҶ’    local tmptar=\"/tmp/deploy-${name}-$$.tar\"\n   186вҶ’    docker save \"$name\" -o \"$tmptar\"\n   187вҶ’\n   188вҶ’    local tar_bytes\n   189вҶ’    tar_bytes=$(stat -f%z \"$tmptar\" 2>/dev/null || stat -c%s \"$tmptar\" 2>/dev/null)\n   190вҶ’    local tar_mb=$(( tar_bytes / 1024 / 1024 ))\n   191вҶ’\n   192вҶ’    echo \"Uploading ${name} (${tar_mb}MB)...\"\n   193вҶ’\n   194вҶ’    # Pipe in 4MB chunks, report progress to stderr (shows in step log)\n   195вҶ’    local bs=4194304\n   196вҶ’    local blocks=$(( (tar_bytes + bs - 1) / bs ))\n   197вҶ’    local i=0\n   198вҶ’\n   199вҶ’    (\n   200вҶ’        while [[ $i -lt $blocks ]]; do\n   201вҶ’            dd if=\"$tmptar\" bs=$bs skip=$i count=1 2>/dev/null\n   202вҶ’            i=$((i + 1))\n   203вҶ’            local pct=$((i * 100 / blocks))\n   204вҶ’            [[ $pct -gt 100 ]] && pct=100\n   205вҶ’            echo \"  ${name}: ${pct}% ($((i * bs / 1024 / 1024))/${tar_mb}MB)\" >&2\n   206вҶ’        done\n   207вҶ’    ) | $SSH_CMD \"docker load\"\n   208вҶ’\n   209вҶ’    rm -f \"$tmptar\"\n   210вҶ’    echo \"${name} loaded.\"\n   211вҶ’}\n   212вҶ’\n   213вҶ’do_transfer_images() {\n   214вҶ’    transfer_image \"desent-server\"\n   215вҶ’    transfer_image \"desent-web\"\n   216вҶ’}\n   217вҶ’\n   218вҶ’do_generate_config() {\n   219вҶ’    local jwt_secret\n   220вҶ’    jwt_secret=$(openssl rand -hex 32)\n   221вҶ’\n   222вҶ’    cat > /tmp/deploy-compose-$$ <<YAML\n   223вҶ’services:\n   224вҶ’  traefik:\n   225вҶ’    image: traefik:v3.3\n   226вҶ’    command:\n   227вҶ’      - --api.insecure=true\n   228вҶ’      - --providers.docker=true\n   229вҶ’      - --providers.docker.exposedbydefault=false\n   230вҶ’      - --entrypoints.web.address=:80\n   231вҶ’    ports:\n   232вҶ’      - \"80:80\"\n   233вҶ’      - \"8080:8080\"\n   234вҶ’    volumes:\n   235вҶ’      - /var/run/docker.sock:/var/run/docker.sock:ro\n   236вҶ’    restart: unless-stopped\n   237вҶ’\n   238вҶ’  server:\n   239вҶ’    image: desent-server:latest\n   240вҶ’    labels:\n   241вҶ’      - traefik.enable=true\n   242вҶ’