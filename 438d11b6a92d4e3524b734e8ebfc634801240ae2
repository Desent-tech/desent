          "type": "user",
          "text": "     1вҶ’package admin\n     2вҶ’\n     3вҶ’import (\n     4вҶ’\t\"encoding/json\"\n     5вҶ’\t\"log/slog\"\n     6вҶ’\t\"math\"\n     7вҶ’\t\"net/http\"\n     8вҶ’\t\"os\"\n     9вҶ’\t\"path/filepath\"\n    10вҶ’\t\"runtime\"\n    11вҶ’\t\"strconv\"\n    12вҶ’\t\"strings\"\n    13вҶ’\t\"time\"\n    14вҶ’\n    15вҶ’\t\"twitch-desent/internal/auth\"\n    16вҶ’\t\"twitch-desent/internal/ingest\"\n    17вҶ’)\n    18вҶ’\n    19вҶ’// IngestManager is the subset of ingest.Manager used by admin endpoints.\n    20вҶ’type IngestManager interface {\n    21вҶ’\tIsLive() bool\n    22вҶ’\tEnabledQualities() []string\n    23вҶ’\tSetQualities(names []string)\n    24вҶ’\tFPSOverrides() map[string]int\n    25вҶ’\tSetFPSOverrides(overrides map[string]int)\n    26вҶ’\tRestart()\n    27вҶ’\tStartedAt() time.Time\n    28вҶ’}\n    29вҶ’\n    30вҶ’type Handler struct {\n    31вҶ’\tstore     *Store\n    32вҶ’\tingestMgr IngestManager\n    33вҶ’\thlsDir    string\n    34вҶ’\tdefaultBW int\n    35вҶ’}\n    36вҶ’\n    37вҶ’func NewHandler(store *Store, ingestMgr IngestManager, hlsDir string, defaultBW int) *Handler {\n    38вҶ’\treturn &Handler{\n    39вҶ’\t\tstore:     store,\n    40вҶ’\t\tingestMgr: ingestMgr,\n    41вҶ’\t\thlsDir:    hlsDir,\n    42вҶ’\t\tdefaultBW: defaultBW,\n    43вҶ’\t}\n    44вҶ’}\n    45вҶ’\n    46вҶ’func (h *Handler) RegisterRoutes(mux *http.ServeMux, mw func(http.Handler) http.Handler) {\n    47вҶ’\tmux.Handle(\"GET /api/admin/settings\", mw(http.HandlerFunc(h.getSettings)))\n    48вҶ’\tmux.Handle(\"PUT /api/admin/settings\", mw(http.HandlerFunc(h.updateSettings)))\n    49вҶ’\tmux.Handle(\"GET /api/admin/users\", mw(http.HandlerFunc(h.listUsers)))\n    50вҶ’\tmux.Handle(\"POST /api/admin/ban\", mw(http.HandlerFunc(h.banUser)))\n    51вҶ’\tmux.Handle(\"DELETE /api/admin/ban/{userId}\", mw(http.HandlerFunc(h.unbanUser)))\n    52вҶ’\tmux.Handle(\"GET /api/admin/stats\", mw(http.HandlerFunc(h.getStats)))\n    53вҶ’\tmux.Handle(\"GET /api/admin/qualities\", mw(http.HandlerFunc(h.getQualities)))\n    54вҶ’\tmux.Handle(\"PUT /api/admin/qualities\", mw(http.HandlerFunc(h.updateQualities)))\n    55вҶ’}\n    56вҶ’\n    57вҶ’func (h *Handler) getSettings(w http.ResponseWriter, r *http.Request) {\n    58вҶ’\tsettings, err := h.store.GetSettings(r.Context())\n    59вҶ’\tif err != nil {\n    60вҶ’\t\tslog.Error(\"admin: get settings\", \"err\", err)\n    61вҶ’\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n    62вҶ’\t\treturn\n    63вҶ’\t}\n    64вҶ’\twriteJSON(w, http.StatusOK, settings)\n    65вҶ’}\n    66вҶ’\n    67вҶ’func (h *Handler) updateSettings(w http.ResponseWriter, r *http.Request) {\n    68вҶ’\tvar kv map[string]string\n    69вҶ’\tif err := json.NewDecoder(r.Body).Decode(&kv); err != nil {\n    70вҶ’\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"invalid JSON\"})\n    71вҶ’\t\treturn\n    72вҶ’\t}\n    73вҶ’\tif len(kv) == 0 {\n    74вҶ’\t\twriteJSON(w, http.StatusBadRequest, map[string]string{\"error\": \"empty payload\"})\n    75вҶ’\t\treturn\n    76вҶ’\t}\n    77вҶ’\n    78вҶ’\tif err := h.store.UpdateSettings(r.Context(), kv); err != nil {\n    79вҶ’\t\tslog.Error(\"admin: update settings\", \"err\", err)\n    80вҶ’\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n    81вҶ’\t\treturn\n    82вҶ’\t}\n    83вҶ’\n    84вҶ’\tsettings, err := h.store.GetSettings(r.Context())\n    85вҶ’\tif err != nil {\n    86вҶ’\t\tslog.Error(\"admin: get settings after update\", \"err\", err)\n    87вҶ’\t\twriteJSON(w, http.StatusInternalServerError, map[string]string{\"error\": \"internal error\"})\n    88вҶ’\t\treturn\n    89вҶ’\t}\n    90вҶ’\twriteJSON(w, http.StatusOK, settings)\n    91вҶ’}\n    92вҶ’\n    93вҶ’func (h *Handler) listUsers(w http.ResponseWriter, r *http.Request) {\n    94вҶ’\tusers, err := h.store.ListUsers(r.Context())\n    95вҶ’\tif err != nil {\n    96вҶ’\t\tslog.Error(\"admin: li